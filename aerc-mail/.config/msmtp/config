# msmtp — SMTP sending for aerc. Secrets via `pass`; select account with -a <address>.
# Gmail uses an App Password (the same one stored for mbsync).

defaults
auth           on
tls            on
tls_starttls   on
logfile        ~/.local/share/msmtp.log

account        av@lab828.com
host           smtp.gmail.com
port           587
from           av@lab828.com
user           av@lab828.com
passwordeval   "pass show email/av@lab828.com"

account        av@dravid.com
host           smtp.gmail.com
port           587
from           av@dravid.com
user           av@dravid.com
