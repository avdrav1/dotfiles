[Unit]
Description=Periodically sync mail with mbsync

[Timer]
# First run shortly after login, then every 5 minutes after each completed run.
OnStartupSec=2m
OnUnitActiveSec=5m
# Catch up a missed run (e.g. laptop was asleep) instead of waiting a full cycle.
Persistent=true

[Install]
WantedBy=timers.target
