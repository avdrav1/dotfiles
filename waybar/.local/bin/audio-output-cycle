#!/bin/bash
# Cycle audio output between Generic, DX5 II, and E2x2

SINKS=(
  "alsa_output.pci-0000_08_00.4.analog-stereo"
  "alsa_output.usb-Topping_DX5_II-00.HiFi__Headphones__sink"
  "alsa_output.usb-Topping_E2x2-00.pro-output-0"
)

NAMES=(
  "Generic"
  "DX5 II"
  "E2x2"
)

ICONS=(
  "audio-speakers"
  "audio-headphones"
  "audio-card"
)

# Get current default sink
current=$(pactl get-default-sink)

# Find current index
current_idx=-1
for i in "${!SINKS[@]}"; do
  if [[ "${SINKS[$i]}" == "$current" ]]; then
    current_idx=$i
    break
  fi
done

# Cycle to next
next_idx=$(( (current_idx + 1) % ${#SINKS[@]} ))
next_sink="${SINKS[$next_idx]}"
next_name="${NAMES[$next_idx]}"
next_icon="${ICONS[$next_idx]}"

# Set new default
pactl set-default-sink "$next_sink"

# Move all active streams to new sink
pactl list sink-inputs short | while read -r input_id _rest; do
  pactl move-sink-input "$input_id" "$next_sink" 2>/dev/null
done

# Notify
notify-send -h string:x-canonical-private-synchronous:audio-switch \
  -i "$next_icon" "Audio Output" "$next_name" -t 2000
