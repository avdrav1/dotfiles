#!/usr/bin/env bash
# DNS health-check: detects systemd-resolved degradation, timeout-rate spikes,
# IPC unresponsiveness, and lookup latency. Emits desktop + journal alerts.
#
# Designed to be invoked periodically by dns-health-check.timer.

set -uo pipefail

# ----- Tunables ------------------------------------------------------------
TIMEOUT_RATE_PCT_ALERT=${TIMEOUT_RATE_PCT_ALERT:-15}   # % of new transactions
MIN_NEW_TX_FOR_RATE=${MIN_NEW_TX_FOR_RATE:-20}         # avoid noise on idle
LATENCY_MS_ALERT=${LATENCY_MS_ALERT:-500}              # uncached lookup
PROBE_HOST=${PROBE_HOST:-archlinux.org}
IPC_TIMEOUT_S=${IPC_TIMEOUT_S:-10}
JOURNAL_LOOKBACK=${JOURNAL_LOOKBACK:-6 minutes ago}    # > timer interval
STATE_DIR=${STATE_DIR:-$HOME/.cache/dns-health-check}
STATE_FILE="$STATE_DIR/state"
TAG="dns-health-check"

mkdir -p "$STATE_DIR"

# ----- Helpers -------------------------------------------------------------
log()    { logger -t "$TAG" -- "$*"; printf '%s\n' "$*"; }
notify() {
  local urgency=$1 title=$2 body=$3
  log "[$urgency] $title â€” $body"
  # Try to deliver to the active graphical session.
  if command -v notify-send >/dev/null 2>&1; then
    notify-send -a "$TAG" -u "$urgency" -i network-error -- "$title" "$body" || true
  fi
}

# ----- Probe 1: resolvectl IPC ---------------------------------------------
stats_raw=$(timeout "$IPC_TIMEOUT_S" resolvectl statistics 2>&1)
stats_rc=$?
if [[ $stats_rc -ne 0 ]]; then
  notify critical "DNS resolver IPC unresponsive" \
    "resolvectl statistics exit=$stats_rc within ${IPC_TIMEOUT_S}s. systemd-resolved may be stuck."
  # Continue â€” other probes may still work.
fi

# Parse current totals (may be empty if IPC failed).
total_tx=$(grep -E "Total Transactions" <<<"$stats_raw" | awk '{print $NF}')
total_to=$(grep -E "Total Timeouts:" <<<"$stats_raw" | awk '{print $NF}')
total_fail=$(grep -E "Total Failure Responses:" <<<"$stats_raw" | awk '{print $NF}')

# ----- Probe 2: journal degradation messages -------------------------------
deg_lines=$(journalctl -u systemd-resolved --no-pager \
              --since "$JOURNAL_LOOKBACK" 2>/dev/null \
              | grep -F "Using degraded feature set" || true)
if [[ -n "$deg_lines" ]]; then
  # Per-server breakdown.
  servers=$(awk -F'for DNS server ' '/Using degraded feature set/ {print $2}' \
              <<<"$deg_lines" | sed 's/\.$//' | sort -u | paste -sd ', ' -)
  count=$(wc -l <<<"$deg_lines")
  notify normal "DNS feature-set degradation" \
    "${count} downgrade events in last window. Servers: ${servers:-unknown}"
fi

# ----- Probe 3: timeout-rate delta -----------------------------------------
prev_tx=0; prev_to=0; prev_fail=0
if [[ -f "$STATE_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$STATE_FILE"
fi

if [[ -n "${total_tx:-}" && -n "${total_to:-}" ]]; then
  delta_tx=$(( total_tx - prev_tx ))
  delta_to=$(( total_to - prev_to ))
  delta_fail=$(( ${total_fail:-0} - prev_fail ))

  # Counters reset (e.g. resolved restarted): re-baseline silently.
  if (( delta_tx < 0 || delta_to < 0 )); then
    delta_tx=0; delta_to=0; delta_fail=0
  fi

  if (( delta_tx >= MIN_NEW_TX_FOR_RATE )); then
    rate=$(( (delta_to * 100) / delta_tx ))
    if (( rate >= TIMEOUT_RATE_PCT_ALERT )); then
      notify critical "DNS timeout rate elevated" \
        "${rate}% (${delta_to}/${delta_tx} new tx) â‰Ą ${TIMEOUT_RATE_PCT_ALERT}% threshold."
    fi
  fi

  if (( delta_fail > 0 )); then
    notify critical "DNS failure responses observed" \
      "${delta_fail} new failure response(s) in last interval."
  fi
fi

# ----- Probe 4: live lookup latency ----------------------------------------
# Bypass cache by appending a random subdomain that will NXDOMAIN â€” we measure
# round-trip, not cached fast-path.
probe_host="probe-$(date +%s%N).${PROBE_HOST}"
start_ns=$(date +%s%N)
timeout 5 getent hosts "$probe_host" >/dev/null 2>&1 || true
end_ns=$(date +%s%N)
latency_ms=$(( (end_ns - start_ns) / 1000000 ))

if (( latency_ms >= LATENCY_MS_ALERT )); then
  notify normal "DNS lookup latency high" \
    "Probe to ${PROBE_HOST} took ${latency_ms}ms (â‰Ą ${LATENCY_MS_ALERT}ms)."
fi

# ----- Persist state -------------------------------------------------------
{
  echo "prev_tx=${total_tx:-$prev_tx}"
  echo "prev_to=${total_to:-$prev_to}"
  echo "prev_fail=${total_fail:-$prev_fail}"
  echo "last_run=$(date -Is)"
  echo "last_latency_ms=$latency_ms"
} > "$STATE_FILE"

log "ok tx=${total_tx:-?} to=${total_to:-?} fail=${total_fail:-?} latency=${latency_ms}ms"
